function t(key) {
  return i18n[currentLang][key] || i18n['tr'][key] || key;
}

function setLang(lang) {
  currentLang = lang;
  document.getElementById('btn-tr').classList.toggle('active', lang === 'tr');
  document.getElementById('btn-en').classList.toggle('active', lang === 'en');
  document.documentElement.lang = lang;

  // Update all data-i18n elements
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    if (i18n[lang][key] !== undefined) el.textContent = i18n[lang][key];
  });

  // Update HTML content (hero title with em tag)
  document.querySelectorAll('[data-i18n-html]').forEach(el => {
    const key = el.getAttribute('data-i18n-html');
    if (i18n[lang][key] !== undefined) el.innerHTML = i18n[lang][key];
  });

  // Update placeholders
  document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
    const key = el.getAttribute('data-i18n-placeholder');
    if (i18n[lang][key] !== undefined) el.placeholder = i18n[lang][key];
  });

  // Re-render dynamic content
  renderAlumni();
  renderConversations();

  // Update chat greeting if chat is fresh (only first msg)
  const chatMsgs = document.getElementById('chatMessages');
  if (chatMsgs && chatMsgs.children.length === 1) {
    chatMsgs.innerHTML = `
      <div class="msg ai">
        <div class="msg-avatar msg-ai-av">✦</div>
        <div class="msg-bubble">
          <p>${t('greeting')}</p>
          <p>${t('greeting2')}</p>
          <p>${t('greeting3')}</p>
        </div>
      </div>
    `;
  }

  // Update empty DM state if visible
  const emptyDm = document.querySelector('.empty-dm .em-text');
  if (emptyDm) emptyDm.textContent = t('select_conv');

  // Update active conv if open
  if (activeConv) openConv(activeConv);
}

