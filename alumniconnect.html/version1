// ─── RENDER CONVERSATIONS ────────────────────────────────────────────
function renderConversations() {
  const list = document.getElementById('convList');
  list.innerHTML = conversations.map(c => `
    <div class="conv-item ${activeConv === c.id ? 'active' : ''}" onclick="openConv(${c.id})">
      <div class="conv-av" style="background:${c.color}">${c.initials}</div>
      <div style="flex:1;min-width:0">
        <div class="conv-name">${c.name}</div>
        <div class="conv-preview">${c.preview}</div>
      </div>
      <div class="conv-time">${c.time}</div>
    </div>
  `).join('');
}

function openConv(id) {
  activeConv = id;
  const conv = conversations.find(c => c.id === id);
  renderConversations();

  const dmArea = document.getElementById('dmArea');
  dmArea.innerHTML = `
    <div class="dm-header">
      <div class="conv-av" style="background:${conv.color};width:36px;height:36px">${conv.initials}</div>
      <div>
        <div style="font-weight:600;font-size:14px">${conv.name}</div>
        <div style="font-size:12px;color:var(--muted)">${t('online')}</div>
      </div>
    </div>
    <div class="dm-messages" id="dmMsgs">
      ${conv.messages.map(m => `
        <div class="dm-msg ${m.mine ? 'mine' : ''}">
          ${!m.mine ? `<div class="conv-av" style="background:${conv.color};width:28px;height:28px;font-size:10px">${conv.initials}</div>` : ''}
          <div>
            <div class="dm-bubble">${m.text}</div>
            <div class="dm-time">${m.time}</div>
          </div>
        </div>
      `).join('')}
    </div>
    <div class="dm-input-area">
      <input class="dm-input" id="dmInput" placeholder="${t('dm_placeholder')}" onkeydown="sendDM(event, ${conv.id})">
      <button class="send-btn" onclick="sendDMBtn(${conv.id})">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>
  `;
}

function sendDM(e, convId) {
  if (e.key === 'Enter') sendDMBtn(convId);
}

function sendDMBtn(convId) {
  const input = document.getElementById('dmInput');
  const text = input.value.trim();
  if (!text) return;

  const conv = conversations.find(c => c.id === convId);
  const now = new Date();
  const timeStr = `${now.getHours()}:${String(now.getMinutes()).padStart(2,'0')}`;

  conv.messages.push({ mine: true, text, time: timeStr });
  conv.preview = text;
  input.value = '';

  const msgs = document.getElementById('dmMsgs');
  const div = document.createElement('div');
  div.className = 'dm-msg mine';
  div.innerHTML = `<div><div class="dm-bubble">${text}</div><div class="dm-time">${timeStr}</div></div>`;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
  renderConversations();
}

function openDM(name, initials, color) {
  // Check if conv exists
  let conv = conversations.find(c => c.name === name);
  if (!conv) {
    const id = conversations.length + 1;
    conv = { id, name, initials, color, preview: '', time: t('now'), messages: [
      { mine: false, text: t('dm_intro'), time: t('now') }
    ]};
    conversations.push(conv);
  }
  showPage('messages');
  renderConversations();
  setTimeout(() => openConv(conv.id), 50);
}

